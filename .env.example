# Required. Primary cert CN. Must match a live/<SERVER_HOSTNAME>/ directory
# under /etc/letsencrypt once the cert has been issued.
SERVER_HOSTNAME=chat.taram.ca

# Recommended. Space-separated compose service names to SIGHUP after each
# successful renewal.
RELOAD_SERVICES=nginx

# HTTP/HTTPS bindings. Leave the *_BIND empty for IPv4-any; set to an IP to
# restrict. Do not use IP:PORT in HTTP(S)_BIND or HTTP(S)_PORT.
# Avoid ports 8081, 9081, 65510 (reserved by internal services).
HTTP_PORT=80
HTTP_BIND=
HTTPS_PORT=443
HTTPS_BIND=

# Embedding model. HF_TOKEN must be set in your local .env (never commit it).
EMBEDDING_MODEL=OrdalieTech/Solon-embeddings-large-0.1
#HF_TOKEN=

# RAG configuration.
CHUNK_SIZE=512
CHUNK_OVERLAP=256
TOP_K=3

# Reranking configuration.
RERANKER_MODEL=antoinelouis/crossencoder-camembert-base-mmarcoFR
RERANK_CANDIDATES=10

# Ollama configuration.
OLLAMA_MODEL=qwen2.5:3b

# Performance configuration.
DEMO_MODE=0
MAX_TOKENS=512
